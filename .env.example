# ============================================================
# Email Agent 配置模板
# 复制为 .env 并填入你的信息：cp .env.example .env
# ============================================================

# 邮箱配置（setup.py 会自动填写）
EMAIL_IMAP_SERVER=imap.qq.com
EMAIL_SMTP_SERVER=smtp.qq.com
EMAIL_ACCOUNT=your-email@qq.com
EMAIL_PASSWORD=your-auth-code
EMAIL_INBOX_FOLDER=INBOX

# 运行模式：false=真实邮箱，true=模拟测试
MOCK_MODE=false

# AI 增强（可选）
# OPENAI_API_KEY=sk-xxx
# GEMINI_API_KEY=xxx
